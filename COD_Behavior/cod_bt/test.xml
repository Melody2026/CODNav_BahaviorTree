<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main_tree">
  <BehaviorTree ID="Main_tree">
    <Sequence>
      <PubNav2Goal goal_pose="{main_position}"
                   frame_id="map"/>
      <KeepRunningUntilFailure>
        <ReactiveFallback>
          <Inverter>
            <WriteToBlackboard Hp="{hp}"
                               Zone_status="{zone_status}"
                               Is_defence="{is_defence}"
                               Is_attack="{is_attack}"
                               Self_status="{self_status}"
                               Is_recover="{is_recover}"/>
          </Inverter>
          <Sequence>
            <HpCondition Hp="{hp}"/>
            <ReactiveSequence>
              <PubNav2Goal goal_pose="{home_position}"
                           frame_id="map"/>
              <StayHome Hp="{hp}"/>
            </ReactiveSequence>
          </Sequence>
          <Sequence>
            <Delay delay_msec="7000">
              <SendNav2Goal goal_pose="{ap_position1}"/>
            </Delay>
            <Delay delay_msec="7000">
              <SendNav2Goal goal_pose="{ap_position2}"/>
            </Delay>
          </Sequence>
          <AlwaysSuccess/>
        </ReactiveFallback>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="HpCondition"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Action ID="PubNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="frame_id"/>
    </Action>
    <Action ID="SendNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
    </Action>
    <Condition ID="StayHome"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Action ID="WriteToBlackboard"
            editable="true">
      <output_port name="Hp"/>
      <output_port name="Zone_status"/>
      <output_port name="Is_defence"/>
      <output_port name="Is_attack"/>
      <output_port name="Self_status"/>
      <output_port name="Is_recover"/>
    </Action>
  </TreeNodesModel>

</root>
