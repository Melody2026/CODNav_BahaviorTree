<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main_tree">
  <BehaviorTree ID="Main_tree">
    <Sequence>
      <SendNav2Goal goal_pose="{main_position}"/>
      <KeepRunningUntilFailure>
        <ReactiveFallback>
          <Inverter>
            <WriteToBlackboard Position="{position}"
                               Hp="{hp}"
                               Zone_status="{zone_status}"
                               Is_attacted="{is_attacted}"/>
          </Inverter>
          <ReactiveFallback>
            <Sequence>
              <HpCondition Hp="{hp}"/>
              <SendNav2Goal goal_pose="{home_position}"/>
            </Sequence>
            <Rapid_spin Is_attacted="{is_attacted}"/>
            <Inverter>
              <Fallback>
                <ZsCondition Zone_status="{zone_status}"/>
                <SendNav2Goal goal_pose="{home_position}"/>
              </Fallback>
            </Inverter>
          </ReactiveFallback>
          <Rapid_spin Is_attacted="{is_attacted}"/>
          <AlwaysSuccess/>
        </ReactiveFallback>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Patrol_tree">
    <Sequence>
      <IsPatrolCondition Hp="{hp}"
                         Zone_status="{zone_status}"/>
      <GetNextPatrolPose Patrol_pose="{patrol_pose}"/>
      <SendNav2Goal goal_pose="{patrol_pose}"/>
      <UpdataPatrolIndex/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="GetNextPatrolPose"
            editable="true">
      <output_port name="Patrol_pose"/>
    </Action>
    <Condition ID="HpCondition"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Condition ID="IsPatrolCondition"
               editable="true">
      <input_port name="Hp"/>
      <input_port name="Zone_status"/>
    </Condition>
    <Action ID="Rapid_spin"
            editable="true">
      <input_port name="Is_attacted"/>
    </Action>
    <Action ID="SendNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
    </Action>
    <Action ID="UpdataPatrolIndex"
            editable="true"/>
    <Action ID="WriteToBlackboard"
            editable="true">
      <output_port name="Position"/>
      <output_port name="Hp"/>
      <output_port name="Zone_status"/>
      <output_port name="Is_attacted"/>
    </Action>
    <Condition ID="ZsCondition"
               editable="true">
      <input_port name="Zone_status"/>
    </Condition>
  </TreeNodesModel>

</root>
