<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main_tree">
  <BehaviorTree ID="Main_tree">
    <Sequence>
      <RetryUntilSuccessful num_attempts="9999">
        <Parallel failure_count="2"
                  success_count="2">
          <SendNav2Goal goal_pose="{main_position}"/>
          <CheckNavArrived goal_pose="{main_position}"
                           tolerance="0.3"/>
        </Parallel>
      </RetryUntilSuccessful>
      <KeepRunningUntilFailure>
        <Fallback>
          <Inverter>
            <WriteToBlackboard Position="{position}"
                               Hp="{hp}"
                               Zone_status="{zone_status}"/>
          </Inverter>
          <Sequence>
            <HpCondition Hp="{hp}"/>
            <Parallel failure_count="2"
                      success_count="2">
              <SendNav2Goal goal_pose="{home_position}"/>
              <CheckNavArrived goal_pose="{home_position}"
                               tolerance="0.3"/>
            </Parallel>
          </Sequence>
          <Parallel failure_count="2"
                    success_count="2">
            <SendNav2Goal goal_pose="{home_position}"/>
            <CheckNavArrived goal_pose="{home_position}"
                             tolerance="0.3"/>
          </Parallel>
          <AlwaysSuccess/>
        </Fallback>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Patrol_tree">
    <Sequence>
      <IsPatrolCondition Hp="{hp}"
                         Zone_status="{zone_status}"/>
      <GetNextPatrolPose Patrol_pose="{patrol_pose}"/>
      <SendNav2Goal goal_pose="{patrol_pose}"/>
      <UpdataPatrolIndex/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="CheckNavArrived"
               editable="true">
      <input_port name="goal_pose"/>
      <input_port name="tolerance"/>
    </Condition>
    <Action ID="GetNextPatrolPose"
            editable="true">
      <output_port name="Patrol_pose"/>
    </Action>
    <Condition ID="HpCondition"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Condition ID="IsPatrolCondition"
               editable="true">
      <input_port name="Hp"/>
      <input_port name="Zone_status"/>
    </Condition>
    <Action ID="SendNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
    </Action>
    <Action ID="UpdataPatrolIndex"
            editable="true"/>
    <Action ID="WriteToBlackboard"
            editable="true">
      <inout_port name="Position"/>
      <inout_port name="Hp"/>
      <output_port name="Zone_status"/>
    </Action>
  </TreeNodesModel>

</root>
