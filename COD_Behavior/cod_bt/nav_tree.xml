<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main_tree">
  <BehaviorTree ID="Main_tree">
    <Sequence>
      <KeepRunningUntilFailure>
        <ReactiveFallback>
          <Inverter>
            <WriteToBlackboard Hp="{hp}"
                               Zone_status="{zone_status}"
                               Is_defence="{is_defence}"
                               Is_attack="{is_attack}"
                               Self_status="{self_status}"
                               Is_recover="{is_recover}"
                               MatchStarted="{match_started}"/>
          </Inverter>
          <Sequence>
            <HpCondition Hp="{hp}"/>
            <ReactiveSequence>
              <PubNav2Goal goal_pose="{home_position}"
                           frame_id="map"
                           min_pub_interval_ms="500"/>
              <PubSlowState slow_state="0"/>
              <StayHome Hp="{hp}"/>
            </ReactiveSequence>
          </Sequence>
          <Sequence>
            <Fallback>
              <Sequence>
                <BaseLinkInRectangle point1="{ap_position1}"
                                     point2="{ap_position2}"
                                     target_frame="map"
                                     base_frame="base_link"/>
                <PubSlowState slow_state="2"/>
              </Sequence>
              <PubSlowState slow_state="1"/>
            </Fallback>
            <ReactiveSequence>
              <Inverter>
                <HpCondition Hp="{hp}"/>
              </Inverter>
              <PubNav2Goal goal_pose="{ap_position1}"
                           frame_id="map"
                           min_pub_interval_ms="500"/>
              <WaitUntilReached goal_pose="{ap_position1}"
                                tolerance="0.2"/>
            </ReactiveSequence>
            <ReactiveSequence>
              <Inverter>
                <HpCondition Hp="{hp}"/>
              </Inverter>
              <PubNav2Goal goal_pose="{ap_position2}"
                           frame_id="map"
                           min_pub_interval_ms="500"/>
              <WaitUntilReached goal_pose="{ap_position2}"
                                tolerance="0.2"/>
            </ReactiveSequence>
          </Sequence>
          <AlwaysSuccess/>
        </ReactiveFallback>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="BaseLinkInRectangle"
               editable="true">
      <input_port name="point1"/>
      <input_port name="point2"/>
      <input_port name="target_frame"/>
      <input_port name="base_frame"/>
    </Condition>
    <Condition ID="HpCondition"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Action ID="PubNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="frame_id"/>
      <input_port name="min_pub_interval_ms"/>
    </Action>
    <Action ID="PubSlowState"
            editable="true">
      <input_port name="slow_state"/>
    </Action>
    <Condition ID="StayHome"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Action ID="WaitUntilReached"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="tolerance"/>
    </Action>
    <Action ID="WriteToBlackboard"
            editable="true">
      <output_port name="Hp"/>
      <output_port name="Zone_status"/>
      <output_port name="Is_defence"/>
      <output_port name="Is_attack"/>
      <output_port name="Self_status"/>
      <output_port name="Is_recover"/>
      <output_port name="MatchStarted"/>
    </Action>
  </TreeNodesModel>

</root>
