<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main_tree">
  <BehaviorTree ID="Main_tree">
    <Sequence>
      <PubNav2Goal goal_pose="{main_position}"
                   frame_id="map"
                   min_pub_interval_ms="500"/>
      <KeepRunningUntilFailure>
        <ReactiveFallback>
          <Inverter>
            <WriteToBlackboard Hp="{hp}"
                               Zone_status="{zone_status}"
                               Is_defence="{is_defence}"
                               Is_attack="{is_attack}"
                               Self_status="{self_status}"
                               Is_recover="{is_recover}"
                               MatchStarted="{match_started}"/>
          </Inverter>
          <Sequence>
            <HpCondition Hp="{hp}"/>
            <ReactiveSequence>
              <PubNav2Goal goal_pose="{home_position}"
                           frame_id="map"
                           min_pub_interval_ms="500"/>
              <StayHome Hp="{hp}"/>
            </ReactiveSequence>
          </Sequence>
          <Sequence>
            <ReactiveSequence>
              <!-- HpCondition 在低血量时返回 SUCCESS；取反后仅高血量允许前压。 -->
              <Inverter>
                <HpCondition Hp="{hp}"/>
              </Inverter>
              <PubNav2Goal goal_pose="{ap_position1}"
                           frame_id="map"
                           min_pub_interval_ms="500"/>
              <WaitUntilReached goal_pose="{ap_position1}"
                                tolerance="0.2"/>
            </ReactiveSequence>
            <ReactiveSequence>
              <!-- 每次 tick 都先检查血量，低血量会停止该目标的发布。 -->
              <Inverter>
                <HpCondition Hp="{hp}"/>
              </Inverter>
              <PubNav2Goal goal_pose="{ap_position2}"
                           frame_id="map"
                           min_pub_interval_ms="500"/>
              <WaitUntilReached goal_pose="{ap_position2}"
                                tolerance="0.2"/>
            </ReactiveSequence>
          </Sequence>
          <AlwaysSuccess/>
        </ReactiveFallback>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="HpCondition"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Action ID="PubNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="frame_id"/>
      <input_port name="min_pub_interval_ms"/>
    </Action>
    <Condition ID="StayHome"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Action ID="WaitUntilReached"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="tolerance"/>
    </Action>
    <Action ID="WriteToBlackboard"
            editable="true">
      <output_port name="Hp"/>
      <output_port name="Zone_status"/>
      <output_port name="Is_defence"/>
      <output_port name="Is_attack"/>
      <output_port name="Self_status"/>
      <output_port name="Is_recover"/>
      <output_port name="MatchStarted"/>
    </Action>
  </TreeNodesModel>

</root>
